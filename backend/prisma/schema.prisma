generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum QuestionType {
  BOOLEAN
  INPUT
  CHECKBOX
}

model Quiz {
  id        String     @id @default(uuid())
  title     String
  questions Question[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@map("quiz")
}

model Question {
  id      String       @id @default(uuid())
  type    QuestionType
  label   String
  options String[]
  quizId  String
  quiz    Quiz         @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@map("question")
}
